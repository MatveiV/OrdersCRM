# Database Configuration
POSTGRES_DB=crm_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@postgres:5432/crm_db

# pgAdmin Configuration (DEV ONLY)
PGADMIN_DEFAULT_EMAIL=admin@orderscrm.ru
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Application Configuration
APP_PORT=8000
APP_HOST=0.0.0.0
ENVIRONMENT=production
DISABLE_DOCS=true
CORS_ORIGINS=https://orderscrm.ru

# Registry Configuration (DEV ONLY)
REGISTRY_HOST=orderscrm.ru
REGISTRY_PORT=8080

# Watchtower Configuration
WATCHTOWER_SCHEDULE=0 0 4 * *
WATCHTOWER_CLEANUP=true
WATCHTOWER_NOTIFICATIONS=none

# Nginx Configuration
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# JWT Configuration
JWT_SECRET_KEY=orderscrm-prod-jwt-secret-k8sH92mP4vL7xR3wQ5nA1cE6bG8yF0jS
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
